{
  "compilerOptions": {
    "skipLibCheck": true, // tsdown has optional peer deps
    "customConditions": ["@seek/aws-codedeploy-hooks/source"],
    "rootDir": ".",
    "composite": true,
    "lib": ["ES2023"],
    "outDir": "lib",
    "target": "ES2023"
  },
  "exclude": ["lib*/**/*"],
  "extends": "skuba/config/tsconfig.json",
  "include": [
    "jest.config.ts",
    "jest.setup.ts",
    "packages/**/*",
    "packages/**/package.json",
    "**/tsdown.config.mts"
  ]
}
