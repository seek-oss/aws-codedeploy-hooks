{
  "name": "@seek/aws-codedeploy-infra",
  "version": "4.0.4",
  "private": false,
  "description": "AWS CDK infrastructure for AWS CodeDeploy Hooks",
  "homepage": "https://github.com/seek-oss/aws-codedeploy-hooks/tree/main/packages/infra#readme",
  "bugs": {
    "url": "https://github.com/seek-oss/aws-codedeploy-hooks/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/seek-oss/aws-codedeploy-hooks.git"
  },
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "@seek/aws-codedeploy-hooks/source": "./src/index.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.cts",
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "pnpm run --silent codegen && skuba build-package",
    "codegen": "skuba node cli/codegen"
  },
  "dependencies": {
    "@seek/logger": "^12.0.0",
    "@types/aws-lambda": "^8.10.130",
    "aws-cdk-lib": "^2.224.0",
    "constructs": "^10.3.0",
    "skuba-dive": "^4.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "3.998.0",
    "@aws-sdk/client-codedeploy": "3.998.0",
    "@aws-sdk/client-lambda": "3.998.0",
    "@smithy/util-stream": "4.5.15",
    "aws-sdk-client-mock": "4.1.0",
    "aws-sdk-client-mock-jest": "4.1.0",
    "isomorphic-git": "1.37.2",
    "pino-pretty": "13.1.3"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./lib/index.mjs",
        "require": "./lib/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "skuba": {
    "build": "esbuild"
  }
}
