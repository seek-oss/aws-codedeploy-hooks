{
  "name": "@seek/aws-codedeploy-hooks",
  "version": "3.0.0",
  "private": false,
  "description": "Runtime helpers for working with AWS CodeDeploy Hooks",
  "homepage": "https://github.com/seek-oss/aws-codedeploy-hooks/tree/main/packages/hooks#readme",
  "bugs": {
    "url": "https://github.com/seek-oss/aws-codedeploy-hooks/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/seek-oss/aws-codedeploy-hooks.git"
  },
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "@seek/aws-codedeploy-hooks/source": "./src/index.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.cts",
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "skuba build"
  },
  "dependencies": {},
  "devDependencies": {
    "@aws-sdk/client-lambda": "3.998.0",
    "@seek/logger": "^12.0.0",
    "@types/aws-lambda": "^8.10.130",
    "@types/koa": "^3.0.0",
    "@types/supertest": "^6.0.2",
    "koa": "^3.0.1",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./lib/index.mjs",
        "require": "./lib/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "skuba": {
    "build": "esbuild"
  }
}
